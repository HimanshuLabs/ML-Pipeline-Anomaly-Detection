# Project 4 local environment template.
# Copy this file to .env for local runs. Do not commit .env.

PROJECT_NAME=project4-ml-pipeline-anomaly-detection
ENVIRONMENT=local
LOG_LEVEL=INFO

# PostgreSQL target for Project 4 metadata.
# Default assumes Project 2/3 warehouse PostgreSQL container pattern.
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=marketing_analytics
POSTGRES_USER=project2
POSTGRES_PASSWORD=replace_me

# Local artifact registry.
MODEL_ARTIFACT_ROOT=artifacts/models
MLFLOW_TRACKING_URI=file:./mlruns

# Online inference.
API_HOST=0.0.0.0
API_PORT=8001
PREDICTION_LATENCY_P95_BUDGET_MS=200

# Monitoring.
PROMETHEUS_METRICS_ENABLED=true
ALERT_LOG_PATH=logs/alerts/anomaly_alerts.jsonl
PREDICTION_LOG_PATH=logs/predictions/predictions.jsonl
